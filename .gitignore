# ============================================================
# КосмаМед — .gitignore (корень = корень сайта)
# ============================================================

# --- медиа (управляется МойСклад/1С) ---
upload/*

# --- php_interface: init.php + кастомные include (dbconn.php и пр. — нет) ---
bitrix/php_interface/*
!/bitrix/php_interface/init.php
!/bitrix/php_interface/include/ks_phone.php
!/bitrix/php_interface/include/ks_catalog.php
!/bitrix/php_interface/include/kosmamed_body_bg.php

# --- СЕКРЕТЫ ---
bitrix/.settings.php
bitrix/.settings_extra.php

# --- лицензионный ключ Bitrix ---
bitrix/license_key.php
bitrix/*license_key.php
**/license_key.php

# --- кэш / рантайм / бэкапы Bitrix ---
bitrix/managed_cache/*
bitrix/cache/*
bitrix/stack_cache/*
bitrix/html_pages/*
bitrix/backup/*
bitrix/tmp/*
bitrix/updates/*
access/*

# --- логи / дампы / временное ---
*.log
*.sql
*.sql.gz
*.tar.gz
*.bak
*.bak.*

# --- ОС / редакторы ---
.DS_Store
**/.DS_Store
.idea/*
*~
*.swp

# --- окружение-специфичное (как в исходном проекте) ---
.htaccess
sitemap.xml
sitemap-iblock-*.xml
sitemap-files.xml
